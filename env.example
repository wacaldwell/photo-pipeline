# Photo pipeline configuration
# Copy to: .env
#   cp env.example .env
# Do not commit .env (repo .gitignore already covers it).

# Google Gemini API key (for vision analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# WordPress REST API credentials
# Use mvd-clawbase (or the VM hostname) — matches WP_HOME in docker-compose.
WP_URL=http://mvd-clawbase:8087
WP_USER=admin
WP_APP_PASSWORD=your-application-password-here

# Image processing defaults
MAX_WIDTH=1920
JPEG_QUALITY=85
